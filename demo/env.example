# Copy to `demo/.env` and fill in — then `source demo/.env` before running the scripts.
# NEVER commit real secrets. demo/.env is gitignored.

# Public base URL of the deployed environment (staging by default).
export BASE="https://kira-ledger-staging.fly.dev"

# Secrets — read them from Fly, do NOT paste them into any committed file:
#   fly secrets list --app kira-ledger-staging          # shows names only
# The values were set at deploy time; keep them in your password manager.
export API_KEY="REPLACE_ME"          # bearer key for /transfers/payout, /routing, /recon
export WEBHOOK_SECRET="REPLACE_ME"   # HMAC secret for signing /webhooks/chain

# Seeded Northwind account ids (fixed UUIDs, safe to keep here — not secrets).
export USER_ACCOUNT="00000000-0000-0000-0000-000000000002"
export EXTERNAL_ACCOUNT="00000000-0000-0000-0000-000000000001"
export ACH_DEST="00000000-0000-0000-0000-000000000010"
export USDT_DEST="00000000-0000-0000-0000-000000000011"
