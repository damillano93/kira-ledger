# Connection string for Postgres (node-postgres reads this).
DATABASE_URL=postgres://kira:kira@localhost:5432/kira

# Static API key checked by the bearer/API-key middleware for privileged endpoints.
API_KEY=dev-api-key-change-me

# Shared secret used to verify inbound chain-webhook HMAC signatures.
WEBHOOK_SECRET=dev-webhook-secret-change-me

# On-chain confirmations required before a deposit off-ramps (pending -> available).
CONFIRMATIONS=12

# HTTP port the server listens on (defaults to 3000 when unset).
PORT=3000

# --- Chain watcher (Solana devnet) -------------------------------------------
# All optional; the watcher only runs when ENABLE_CHAIN_WATCHER=true.
# Run `npx tsx scripts/devnet-setup.ts` to provision devnet and print these.

# Solana JSON-RPC endpoint.
SOLANA_RPC_URL=https://api.devnet.solana.com

# SPL mint watched for deposits. Vendor abstraction as config: use the test mint
# printed by devnet-setup, or Circle's devnet USDC
# (4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU) — no code change either way.
SOLANA_USDC_MINT=

# Wallet (owner pubkey) whose associated token account receives client deposits.
SOLANA_DEPOSIT_OWNER=

# Off by default so the ledger boots with no chain dependency.
ENABLE_CHAIN_WATCHER=false

# Poll interval for the devnet watcher (milliseconds).
WATCHER_POLL_MS=15000

# Off-ramp fee in basis points taken on the USD leg (100 = 1%).
OFFRAMP_FEE_BPS=100
