# Connection string for Postgres (node-postgres reads this).
DATABASE_URL=postgres://kira:kira@localhost:5432/kira

# Static API key checked by the bearer/API-key middleware for privileged endpoints.
API_KEY=dev-api-key-change-me

# Shared secret used to verify inbound chain-webhook HMAC signatures.
WEBHOOK_SECRET=dev-webhook-secret-change-me

# On-chain confirmations required before a deposit off-ramps (pending -> available).
CONFIRMATIONS=12

# HTTP port the server listens on (defaults to 3000 when unset).
PORT=3000
